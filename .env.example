# ==============================================================
# Single server bootstrap profile (fill this file as .env).
# Scenario: fresh server, only login+password are known.
# ==============================================================

# --- GitHub target ---
GH_REPO_OWNER=NerRobDog
GH_REPO_NAME=Ansible_Servers
GH_ENVIRONMENT=test

# --- Workflow defaults ---
# bootstrap | deploy | lockdown
WORKFLOW_MODE=bootstrap
# Host alias list separated by comma, or "all"
WORKFLOW_LIMIT=all
# true | false
WORKFLOW_CHECK_MODE=false
# Optional ansible tags filter
WORKFLOW_TAGS=

# --- Target host ---
SERVER_ALIAS=test_server_1
SERVER_HOST=203.0.113.10
SERVER_PORT=22

# First access credentials (password auth)
BOOTSTRAP_USERNAME=root
BOOTSTRAP_PASSWORD=CHANGE_ME

# User for subsequent key-based deploys
DEPLOY_USER=deploy

# --- Feature flags ---
FEATURE_BASE=true
FEATURE_DOCKER=true
FEATURE_REMNAWAVE_NODE=true
FEATURE_CADDY_NODE=false
FEATURE_NODE_TUNING=false
FEATURE_USER_SHELL=false

# Optional comma-separated custom roles from roles/
# Example: CUSTOM_ROLES=test_stack,monitoring
CUSTOM_ROLES=

# --- RemaWave node ---
# Required when FEATURE_REMNAWAVE_NODE=true
REMNAWAVE_NODE_SECRET_KEY=CHANGE_ME_FROM_PANEL
REMNAWAVE_NODE_PORT=3001
# enabled | disabled
REMNAWAVE_IPV6_STATE=enabled

# Required only when FEATURE_CADDY_NODE=true
REMNAWAVE_CADDY_DOMAIN=
REMNAWAVE_CADDY_MONITOR_PORT=8443

# --- Optional integrations ---
REMNAWAVE_API_ENDPOINT_TEMPLATE=
RW_PANEL_API_TOKEN=
ANSIBLE_VAULT_PASSWORD=

# Notes:
# 1) SSH keys on server are NOT required initially.
# 2) In bootstrap mode, GitHub runner key is copied to the server.
# 3) Runner private key is stored in GitHub Secret ANSIBLE_SSH_PRIVATE_KEY.
