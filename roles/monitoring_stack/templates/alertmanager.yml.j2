global:
  resolve_timeout: 5m

templates:
  - /etc/alertmanager/templates/*.tmpl

route:
  receiver: telegram-info
  group_by: [alertname, instance, severity]
  group_wait: 15s
  group_interval: 5m
  repeat_interval: 2h
  routes:
    - matchers:
        - severity="critical"
      receiver: telegram-critical
    - matchers:
        - severity="warning"
      receiver: telegram-warning

receivers:
  - name: telegram-critical
    telegram_configs:
      - bot_token: "{{ monitoring_stack_alert_telegram_bot_token_effective }}"
        chat_id: {{ monitoring_stack_alert_telegram_chat_id_effective }}
{% if monitoring_stack_alert_telegram_topic_id_effective | length > 0 %}
        message_thread_id: {{ monitoring_stack_alert_telegram_topic_id_effective }}
{% endif %}
        parse_mode: HTML
        send_resolved: true
        message: '{{ "{{" }} template "telegram.critical.message" . {{ "}}" }}'

  - name: telegram-warning
    telegram_configs:
      - bot_token: "{{ monitoring_stack_alert_telegram_bot_token_effective }}"
        chat_id: {{ monitoring_stack_alert_telegram_chat_id_effective }}
{% if monitoring_stack_alert_telegram_topic_id_effective | length > 0 %}
        message_thread_id: {{ monitoring_stack_alert_telegram_topic_id_effective }}
{% endif %}
        parse_mode: HTML
        send_resolved: true
        message: '{{ "{{" }} template "telegram.warning.message" . {{ "}}" }}'

  - name: telegram-info
    telegram_configs:
      - bot_token: "{{ monitoring_stack_alert_telegram_bot_token_effective }}"
        chat_id: {{ monitoring_stack_alert_telegram_chat_id_effective }}
{% if monitoring_stack_alert_telegram_topic_id_effective | length > 0 %}
        message_thread_id: {{ monitoring_stack_alert_telegram_topic_id_effective }}
{% endif %}
        parse_mode: HTML
        send_resolved: true
        message: '{{ "{{" }} template "telegram.info.message" . {{ "}}" }}'
