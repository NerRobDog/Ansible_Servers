# Ansible Inventory Example
#
# Скопируйте этот файл в hosts.ini и настройте под ваши серверы:
# cp hosts.ini.example hosts.ini
#
# Формат:
# [group_name]
# hostname ansible_host=IP_ADDRESS ansible_user=USERNAME ansible_ssh_private_key_file=PATH_TO_KEY

[servers]
# Примеры серверов (замените на свои данные):
# server1 ansible_host=192.168.1.10 ansible_user=root ansible_ssh_private_key_file=~/.ssh/id_rsa
# server2 ansible_host=192.168.1.11 ansible_user=root ansible_ssh_private_key_file=~/.ssh/id_rsa
# server3 ansible_host=192.168.1.12 ansible_user=root ansible_ssh_private_key_file=~/.ssh/id_rsa

# Вы можете создать несколько групп для разных типов серверов:
# [web]
# web1 ansible_host=192.168.1.20 ansible_user=deploy ansible_ssh_private_key_file=~/.ssh/deploy_key
#
# [db]
# db1 ansible_host=192.168.1.30 ansible_user=deploy ansible_ssh_private_key_file=~/.ssh/deploy_key

