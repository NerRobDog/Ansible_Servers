---
deploy_user: "{{ username }}"
deploy_user_comment: "{{ comment | default('Deployment user') }}"
deploy_user_groups:
  - wheel
  - docker
deploy_user_password_hash: {{ password_hash | default('null') }}
deploy_user_authorized_keys:
  - "{{ ssh_key }}"
deploy_user_passwordless_sudo: {{ passwordless_sudo | default('false') }}
deploy_user_shell: {{ shell | default('/usr/bin/zsh') }}
zsh_theme: {{ zsh_theme | default('afowler') }}
